{
  "name": "m365-mcp",
  "version": "2.0.0",
  "description": "MCP server for Claude to access Microsoft 365 (Outlook, OneDrive, Power Automate) via Microsoft Graph API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:email": "node server-email.js",
    "start:email:read": "node server-email-read.js",
    "start:email:write": "node server-email-write.js",
    "start:email:safewrite": "node server-email-safewrite.js",
    "start:calendar": "node server-calendar.js",
    "start:calendar:read": "node server-calendar-read.js",
    "start:calendar:write": "node server-calendar-write.js",
    "start:onedrive": "node server-onedrive.js",
    "start:onedrive:read": "node server-onedrive-read.js",
    "start:onedrive:write": "node server-onedrive-write.js",
    "start:power-automate": "node server-power-automate.js",
    "start:power-automate:read": "node server-power-automate-read.js",
    "start:power-automate:write": "node server-power-automate-write.js",
    "auth-server": "node outlook-auth-server.js",
    "test-mode": "USE_TEST_MODE=true node index.js",
    "inspect": "npx @modelcontextprotocol/inspector node index.js",
    "test": "jest"
  },
  "keywords": [
    "claude",
    "outlook",
    "onedrive",
    "power-automate",
    "microsoft-365",
    "mcp",
    "microsoft-graph",
    "email"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
